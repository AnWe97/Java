<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<VBox alignment="CENTER" spacing="10" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.MainController">
   <Label text="Enter Username and Password">
      <font>
         <Font size="20.0" />
      </font>
   </Label>
   <Label layoutX="26.0" layoutY="10.0" text="Username" />
   <TextField fx:id="username" maxWidth="300" prefWidth="300" />
   <Label layoutX="133.0" layoutY="50.0" text="Password" />
   <PasswordField fx:id="password" maxWidth="300" prefWidth="300" />
   <Label fx:id="errorLabel" layoutX="135.0" layoutY="112.0" textFill="RED" />
   <Button onAction="#loginButton" prefWidth="150" text="Confirm" />
</VBox>
