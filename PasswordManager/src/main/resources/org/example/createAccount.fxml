<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<VBox alignment="CENTER" prefHeight="240.0" prefWidth="300.0" spacing="10" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.MainController">
   <Label alignment="TOP_CENTER" contentDisplay="TOP" prefHeight="30.0" prefWidth="290.0" text="Create Username and Password" textAlignment="CENTER" textOverrun="CLIP">
      <font>
         <Font size="20.0" />
      </font></Label>
   <Label text="Username" />
    <TextField fx:id="username" maxWidth="300" prefWidth="300" />
   <Label layoutX="133.0" layoutY="89.0" text="Password" />
    <PasswordField fx:id="password" maxWidth="300" prefWidth="300" />
   <Label layoutX="135.0" layoutY="138.0" text="Confirm Password" />
   <PasswordField fx:id="confirmPassword" layoutX="10.0" layoutY="165.0" maxWidth="300" prefWidth="300" />
   <Label fx:id="errorLabel" textAlignment="CENTER" textFill="RED">
      <font>
         <Font size="10.0" />
      </font>
   </Label>
    <Button onAction="#createAccountButton" prefWidth="150" text="Confirm" />
</VBox>